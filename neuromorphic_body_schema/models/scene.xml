<mujoco model="iCub">

  <include file="icub_v2_full_body_improved_contact_sensors.xml"/>

  <option
    cone="elliptic"
    impratio="10"
    timestep="0.002"
    gravity="0 0 -9.81"
    integrator="implicitfast"/>

  <asset>

    <!-- Sky: deep blue-grey gradient, looks clean under the headlight -->
    <texture name="sky"
      type="skybox" builtin="gradient"
      rgb1="0.18 0.26 0.38"
      rgb2="0.04 0.06 0.10"
      width="512" height="3072"/>

    <!-- Floor: subtle dark checker with a faint cross mark -->
    <texture name="tex_floor"
      type="2d" builtin="checker"
      rgb1="0.18 0.20 0.22"
      rgb2="0.12 0.14 0.16"
      width="256" height="256"
      mark="cross" markrgb="0.25 0.27 0.29"/>

    <material name="mat_floor"
      texture="tex_floor"
      texrepeat="6 6" texuniform="true"
      reflectance="0.15"/>

  </asset>

  <visual>

    <!-- Reduce near-plane clipping so close inspection of hand geometry does not get sliced -->
    <map znear="0.0001" zfar="50"/>

    <!-- Headlight: warm fill, no specular blow-out -->
    <headlight
      diffuse="0.55 0.55 0.55"
      ambient="0.25 0.25 0.25"
      specular="0.0  0.0  0.0"/>

    <!-- Subtle atmospheric haze matching the sky colour -->
    <rgba haze="0.12 0.18 0.26 1"/>

    <!-- Default camera angle: slightly raised, looking at standing robot -->
    <global azimuth="185" elevation="-18" offwidth="1280" offheight="720"/>

    <!-- Shadow quality -->
    <quality shadowsize="4096"/>

    <!-- Scale contact force arrows so they are visible but not overwhelming -->
    <scale forcewidth="0.04" contactwidth="0.06" contactheight="0.08"/>

  </visual>

  <worldbody>

    <!-- ===== FLOOR ===== -->
    <!-- pos z matches the robot's floor geom offset so feet land flush -->
    <geom name="floor"
      type="plane"
      material="mat_floor"
      pos="0 0 -0.629438"
      size="6 6 0.01"
      contype="1" conaffinity="63"
      condim="6"/>
    <!-- ===== END FLOOR ===== -->

    <!-- ===== LIGHTS ===== -->

    <!-- Key light: warm, slightly off-axis, casts shadows -->
    <light name="key"
      pos="4 -3 6"
      dir="-0.5 0.4 -1"
      diffuse="0.85 0.80 0.70"
      specular="0.3 0.3 0.3"
      directional="false"
      castshadow="true"/>

    <!-- Fill light: cool, opposite side, no shadows (avoids double shadow) -->
    <light name="fill"
      pos="-4 3 5"
      dir="0.5 -0.4 -0.9"
      diffuse="0.30 0.35 0.45"
      specular="0.0 0.0 0.0"
      directional="false"
      castshadow="false"/>

    <!-- Rim light: behind and above, separates robot from background -->
    <light name="rim"
      pos="0 5 4"
      dir="0 -0.8 -0.6"
      diffuse="0.25 0.30 0.40"
      specular="0.1 0.1 0.1"
      directional="false"
      castshadow="false"/>

    <!-- ===== END LIGHTS ===== -->

    <!-- ===== CAMERAS ===== -->

    <!-- Wide shot: full body visible -->
    <camera name="cam_wide"
      pos="2.0 -2.0 1.2"
      xyaxes="0.7 0.7 0 -0.2 0.2 1"
      fovy="50"/>

    <!-- Front portrait: head and torso -->
    <camera name="cam_front"
      pos="0 -1.8 1.1"
      xyaxes="1 0 0 0 0.15 1"
      fovy="40"/>

    <!-- Side profile -->
    <camera name="cam_side"
      pos="2.2 0 1.0"
      xyaxes="0 1 0 -0.15 0 1"
      fovy="45"/>

    <!-- Low angle: good for foot-contact debugging -->
    <camera name="cam_low"
      pos="1.8 -1.8 0.2"
      xyaxes="0.7 0.7 0 0.1 -0.1 0.5"
      fovy="55"/>

    <!-- ===== END CAMERAS ===== -->

  </worldbody>

</mujoco>